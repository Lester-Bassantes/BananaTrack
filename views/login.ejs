<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="./stylesheets/style.css">

    <title>BananaTrack</title>
</head>

<body>
    <div class="fluid-container d-flex justify-content-center align-items-center">
        <div class="form-container bg-light rounded shadow mt-4">
            <div class="row">
                <div class="col-6 p-4">
                    <div class="text-center">
                        <img src="https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-login-form/lotus.webp"
                            style="width: 185px;" alt="logo">
                        <h4 class="mt-1 mb-5 pb-1">Grupo Palmar</h4>
                    </div>
                    <form method="post" action="/api/login">
                        <p>Ingresa en tu cuenta</p>
                        <div class="form-floating mb-4">
                            <input type="email" id="txtNombreUsuario" class="form-control" name="txtNombreUsuario"
                                placeholder="Correo" required />
                            <label class="form-label" for="txtNombreUsuario" id="lblNombreUsuario">Usuario</label>
                        </div>
                        <div class="form-floating mb-4">
                            <input type="password" id="txtContrasena" class="form-control" name="txtContrasena"
                                placeholder="Contraseña" required />
                            <label class="form-label" for="txtContrasena" id="lblContrasena">Contraseña</label>
                        </div>
                        <div class="text-center pt-1 mb-2 pb-1">
                            <button class="btn btn-outline-primary mb-3 w-100" type="submit"
                                id="btnUsuario">Ingresar</button>
                        </div>
                        <div class="text-center">
                            <a class="text-muted" href="#!" id="olvidoContraseña">¿Olvidaste la
                                contraseña?</a>
                        </div>
                        <div class="d-flex align-items-center justify-content-center pb-4 mt-5">
                            <p class="mb-0 me-2">¿No tienes una cuenta?</p>
                            <button type="button" class="btn btn-outline-danger" id="btnNuevaCuenta">Nueva
                                cuenta</button>
                        </div>
                    </form>
                </div>
                <div class="col-6">
                    <div id="image-container" class="image-container w-100 h-100">
                        <img class="img-fluid w-100 h-100 object-fit-cover" src="./images/banana-port.jpg" alt="Palmar">
                    </div>
                    <div id="form-register-container" class="form-register-container w-100 h-100 d-none">
                        <form>
                            <div class="form-floating mb-4">
                                <input type="text" id="txtNombre" class="form-control" placeholder="Nombre completo"
                                    required />
                                <label class="form-label" for="txtNombre">Nombre completo</label>
                            </div>

                            <div class="form-floating mb-4">
                                <input type="email" id="txtCorreo" class="form-control" placeholder="Correo electrónico"
                                    required />
                                <label class="form-label" for="txtCorreo">Correo electrónico</label>
                            </div>

                            <div class="form-floating mb-4">
                                <input type="date" id="txtFechaNacimiento" class="form-control"
                                    placeholder="Fecha de Nacimiento" required />
                                <label class="form-label" for="txtFechaNacimiento">Fecha de
                                    Nacimiento</label>
                            </div>

                            <div class="form-floating mb-4">
                                <input type="password" id="txtContrasenaRegistro" class="form-control"
                                    placeholder="Contraseña" required />
                                <label class="form-label" for="txtContrasenaRegistro">Contraseña</label>
                            </div>

                            <div class="form-floating mb-4">
                                <input type="password" id="txtConfirmarContrasena" class="form-control"
                                    placeholder="Confirmar Contraseña" required />
                                <label class="form-label" for="txtConfirmarContrasena">Confirmar
                                    Contraseña</label>
                            </div>

                            <div class="text-center pt-1 mb-5 pb-1">
                                <button class="btn btn-outline-success mb-3 w-100" type="submit">Crear
                                    cuenta</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="./javascripts/login_register_animation.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>

</html>