<!DOCTYPE html>
<html lang="en">

<%- include('partials/head')%>

    <body class="d-flex align-items-center justify-content-center vh-100 bg-light">
        <div class="container animate__animated animate__backInUp">
            <div class="row justify-content-center">
                <div class="col-12 col-sm-8 col-md-6 col-lg-4">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <div class="text-center mb-4">
                                <img src="/images/Grupo-Palmar-Logotipo.png" alt="Grupo Palmar Logotipo"
                                    class="img-fluid" style="max-height: 100px;">
                            </div>
                            <form method="post" action="/api/login">
                                <p>Ingresa en tu cuenta</p>
                                <div class="form-floating mb-4">
                                    <input type="email" id="txtNombreUsuario" class="form-control"
                                        name="txtNombreUsuario" placeholder="Correo" required />
                                    <label class="form-label" for="txtNombreUsuario"
                                        id="lblNombreUsuario">Usuario</label>
                                </div>
                                <div class="form-floating mb-4">
                                    <input type="password" id="txtContrasena" class="form-control" name="txtContrasena"
                                        placeholder="Contraseña" required />
                                    <label class="form-label" for="txtContrasena" id="lblContrasena">Contraseña</label>
                                </div>
                                <div class="text-center pt-1 mb-2 pb-1">
                                    <button class="btn btn-outline-success mb-3 w-100" type="submit"
                                        id="btnUsuario">Ingresar</button>
                                </div>
                                <div class="text-center">
                                    <a class="text-muted" href="#!" id="olvidoContraseña">¿Olvidaste la
                                        contraseña?</a>
                                </div>
                                <div class="d-flex align-items-center justify-content-center pb-4 mt-5">
                                    <p class="mb-0 me-2">¿No tienes una cuenta?</p>
                                    <button type="button" class="btn btn-outline-primary" id="btnNuevaCuenta">Nueva
                                        cuenta</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <%- include('partials/scripts') %>
    </body>


</html>