<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="./stylesheets/style.css">

    <title>BananaTrack</title>
</head>

<body>
    <section class="section-background h-100">
        <div class="container py-5 h-100">
            <div class="row d-flex justify-content-center align-items-center h-100">
                <div class="col-xl-10">
                    <div class="card rounded-3 bg-light">
                        <div class="row g-0">
                            <div class="col-lg-6">
                                <div class="card-body p-md-5 mx-md-4">
                                    <div class="text-center">
                                        <img src="https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-login-form/lotus.webp"
                                            style="width: 185px;" alt="logo">
                                        <h4 class="mt-1 mb-5 pb-1">Grupo Palmar</h4>
                                    </div>
                                    <form>
                                        <p>Ingresa en tu cuenta</p>

                                        <div class="form-floating mb-4">
                                            <input type="email" id="txtNombreUsuario" class="form-control"
                                                placeholder="Correo" />
                                            <label class="form-label" for="txtNombreUsuario"
                                                id="lblNombreUsuario">Usuario</label>
                                        </div>

                                        <div class="form-floating mb-4">
                                            <input type="password" id="txtContrasena" class="form-control"
                                                placeholder="Contraseña" />
                                            <label class="form-label" for="txtContrasena"
                                                id="lblContrasena">Contraseña</label>
                                        </div>

                                        <div class="text-center pt-1 mb-2 pb-1">
                                            <button class="btn btn-outline-primary mb-3 w-100" type="submit"
                                                id="btnUsuario">Ingresar</button>
                                        </div>

                                        <div class="text-center">
                                            <a class="text-muted" href="#!" id="olvidoContraseña">¿Olvidaste la
                                                contraseña?</a>
                                        </div>

                                        <div class="d-flex align-items-center justify-content-center pb-4 mt-5">
                                            <p class="mb-0 me-2">¿No tienes una cuenta?</p>
                                            <button type="button" class="btn btn-outline-danger"
                                                id="btnNuevaCuenta">Nueva cuenta</button>
                                        </div>

                                    </form>
                                </div>
                            </div>

                            <div class="col-lg-6 d-flex">
                                <img class="img-fluid w-100 h-100 object-fit-cover" src="./images/banana-port.jpg"
                                    alt="Palmar">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>
</body>

</html>